{# Generated by Cursor #}
{% from "includes/stat-card.njk" import statCard %}
{% from "includes/match-level-description.njk" import matchLevelDescription %}

{% macro matchLevelsTabHeader(title, data, csvPath) %}
  <div class="match-levels-tab-header govuk-!-margin-bottom-6">
    <h2 class="govuk-heading-l govuk-!-margin-top-0 govuk-!-margin-bottom-0">{{ title }}</h2>
    {% set csvQueryPrefix = '&' if '?' in csvPath else '?' %}
    <a class="govuk-button govuk-button--secondary" href="{{ csvPath }}{{ csvQueryPrefix }}startDate={{ data.startDate | urlencode }}&amp;endDate={{ data.endDate | urlencode }}">Download as CSV</a>
  </div>
{% endmacro %}

{% macro matchLevelsSummaryPanel(data) %}
  <div class="stat-card-container govuk-!-margin-bottom-6">
    <h3 class="govuk-heading-m">Level 1 match rates</h3>
    {{ matchLevelDescription(1) }}
    <div class="stat-card-group stat-card-group--match-levels">
      {{ statCard("Matches", data.matchLevelsStats.level1.matches, data.matchLevelsStats.level1.matchesPct, "stat-card--grey") }}
      {{ statCard("No matches", data.matchLevelsStats.level1.noMatches, data.matchLevelsStats.level1.noMatchesPct, "stat-card--grey") }}
      {{ statCard("Total", data.matchLevelsStats.level1.total, "", "stat-card--grey") }}
    </div>
  </div>

  <div class="stat-card-container govuk-!-margin-bottom-6">
    <h3 class="govuk-heading-m">Level 2 match rates</h3>
    {{ matchLevelDescription(2) }}
    <div class="stat-card-group stat-card-group--match-levels">
      {{ statCard("Matches", data.matchLevelsStats.level2.matches, data.matchLevelsStats.level2.matchesPct, "stat-card--blue") }}
      {{ statCard("No matches", data.matchLevelsStats.level2.noMatches, data.matchLevelsStats.level2.noMatchesPct, "stat-card--blue") }}
      {{ statCard("Total", data.matchLevelsStats.level2.total, "", "stat-card--blue") }}
    </div>
  </div>

  <div class="stat-card-container govuk-!-margin-bottom-6">
    <h3 class="govuk-heading-m">Level 3 match rates</h3>
    {{ matchLevelDescription(3) }}
    <div class="stat-card-group stat-card-group--match-levels">
      {{ statCard("Matches", data.matchLevelsStats.level3.matches, data.matchLevelsStats.level3.matchesPct, "stat-card--grey") }}
      {{ statCard("No matches", data.matchLevelsStats.level3.noMatches, data.matchLevelsStats.level3.noMatchesPct, "stat-card--grey") }}
      {{ statCard("Total", data.matchLevelsStats.level3.total, "", "stat-card--grey") }}
    </div>
  </div>
{% endmacro %}

