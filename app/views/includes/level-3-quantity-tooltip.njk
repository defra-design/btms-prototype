{# Generated by Cursor #}
{% macro level3QuantityTooltip(displayQty, commodityCode, chedPpRef, mrnQty, chedQty, difference) %}
  <span class="matching-view__today">{{ displayQty }}</span>
  <span class="matching-view__level-3" tabindex="0">
    <span class="tooltiplink error">{{ displayQty }}</span>
    <span class="tooltip tooltip--level-3" role="tooltip">
      <strong class="tooltip--level-3__title">Why this item does not match</strong>
      <p class="tooltip--level-3__intro govuk-!-font-size-14">For commodity code <strong>{{ commodityCode }}</strong>, the quantity or weight on this customs declaration (<strong>{{ displayQty }}</strong>) does not match the total on <strong>{{ chedPpRef }}</strong> (<strong>{{ chedQty }}</strong>).</p>
      <table class="tooltip--level-3__table">
        <tbody>
          <tr>
            <th scope="row">Declared on MRN</th>
            <td>{{ mrnQty }}</td>
          </tr>
          <tr>
            <th scope="row">Total on CHED</th>
            <td>{{ chedQty }}</td>
          </tr>
          <tr class="tooltip--level-3__difference">
            <th scope="row">Difference</th>
            <td><strong>{{ difference }}</strong></td>
          </tr>
        </tbody>
      </table>
    </span>
  </span>
{% endmacro %}
